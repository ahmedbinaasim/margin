# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed and must NEVER contain real secrets.

# --- API service ---
DATABASE_URL=postgresql://margin:margin@localhost:5432/margin
JWT_SECRET=change_me_to_32_random_bytes_hex
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
# Render (and most PaaS) inject PORT at runtime; default to 8080 locally.
PORT=8080

# Embeddings (Voyage)
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3.5-lite
VOYAGE_EMBED_DIM_RAW=1024
EMBED_DIM=768

# LLM (Groq)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare R2
# R2_ENDPOINT is account-scoped: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# Do NOT append the bucket name; boto3 sends it via Bucket=<name>.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=margin-pages
R2_ENDPOINT=

# Email (SMTP — provider-agnostic via aiosmtplib).
# Used ONLY for the welcome email on first login. Non-blocking: if any of
# these are unset or the send fails, sign-in still succeeds. For Gmail,
# SMTP_PASSWORD must be a Google App Password
# (https://myaccount.google.com/apppasswords) — Gmail rejects regular
# passwords. Gmail also requires SMTP_FROM's address to match SMTP_USERNAME.
# Other providers: Resend (smtp.resend.com:465 user=resend pass=<api_key>);
# Brevo (smtp-relay.brevo.com:587); SMTP2GO (mail.smtp2go.com:2525).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM=Margin <you@gmail.com>
# Pick exactly ONE of these. STARTTLS (port 587) is the safe default; implicit
# TLS (port 465) is faster but some hosts (e.g. Render free) block outbound 465.
SMTP_USE_TLS=false
SMTP_START_TLS=true

# Firebase Auth — Admin SDK (server) credentials. From the service-account
# JSON downloaded from Firebase Console → Project settings → Service accounts.
# FIREBASE_PRIVATE_KEY contains literal "\n" sequences (matching the JSON
# format); Python expands them back to real newlines before the PEM parser.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Web app
NEXT_PUBLIC_API_BASE=http://localhost:8080
# Firebase Web SDK (client) — from Firebase Console → Project settings → General
# → Your apps. Public values; safe to commit (they identify the project, not auth).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Tests
TEST_DATABASE_URL=postgresql://margin:margin@localhost:5432/margin_test
