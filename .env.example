# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed and must NEVER contain real secrets.

# --- API service ---
DATABASE_URL=postgresql://margin:margin@localhost:5432/margin
JWT_SECRET=change_me_to_32_random_bytes_hex
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
# Render (and most PaaS) inject PORT at runtime; default to 8080 locally.
PORT=8080

# Embeddings (Voyage)
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3.5-lite
VOYAGE_EMBED_DIM_RAW=1024
EMBED_DIM=768

# LLM (Groq)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare R2
# R2_ENDPOINT is account-scoped: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# Do NOT append the bucket name; boto3 sends it via Bucket=<name>.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=margin-pages
R2_ENDPOINT=

# Email (optional; if unset, magic-link code is returned in the API response for dev)
RESEND_API_KEY=

# Web app
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Tests
TEST_DATABASE_URL=postgresql://margin:margin@localhost:5432/margin_test
